---
// Lay out direct children side by side in a responsive grid.
// Usage: <Columns cols={3}><div>…</div><div>…</div><div>…</div></Columns>
interface Props {
  cols?: 2 | 3 | 4;
  gap?: "sm" | "md" | "lg";
  class?: string;
}

const { cols = 2, gap = "md", class: className } = Astro.props;

const colsClass = {
  2: "md:grid-cols-2",
  3: "md:grid-cols-3",
  4: "md:grid-cols-2 lg:grid-cols-4",
}[cols];

const gapClass = { sm: "gap-4", md: "gap-6", lg: "gap-8" }[gap];
---

<div class:list={["grid grid-cols-1", colsClass, gapClass, className]}>
  <slot />
</div>
