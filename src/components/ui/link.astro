---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-5 py-2.5",
  md: "px-4 py-2",
};

const styles = {
  outline:
    "bg-paper-white border border-ink/15 hover:bg-paper-2 text-ink",
  primary:
    "bg-ink text-white hover:bg-[#333333] border border-transparent shadow-sm",
  inverted: "bg-white text-ink border border-transparent",
  muted: "bg-paper-3 hover:bg-line-2 text-ink border border-transparent",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "inline-flex items-center justify-center gap-1 rounded-lg text-sm font-medium text-center transition focus-visible:ring-2 ring-offset-2 ring-ink/10",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</a>
