---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
  <section class="hero">
    <h1 class="typewriter" data-text="einsia Lab — Accelerating AI's Evolution in Real-World Engineering.">
      einsia Lab — Accelerating AI's Evolution in Real-World Engineering.
    </h1>
    <div class="hero-divider"></div>
    <p>
      We build benchmarks and tools to evaluate frontier AI capabilities in real-world engineering and scientific domains — from aerospace optimization to EDA, quantum computing, and beyond.
    </p>
    <p>
      For inquiries, you can reach us at <a href="mailto:lab@einsia.ai"><b>lab@einsia.ai</b></a>.
    </p>

    <div class="dict-entry">
      <div class="dict-headword">
        <span class="dict-word">einsia</span>
        <span class="dict-phonetic">/ˈaɪniʒə/</span>
      </div>
      <div class="dict-body">
        <span class="dict-pos">n.</span>
        <span class="dict-def"><b>Ein</b> (one) + <b>sia</b> (from <em>science</em>) — A singular focus on rigorous, real-world engineering intelligence.</span>
      </div>
    </div>
  </section>

  <div class="cta">
    <p>Explore our open-source benchmarks and track the frontier of AI engineering.</p>
    <div class="cta-actions">
      <a href="/benchmarks" class="button primary">View Benchmarks</a>
      <a href="https://github.com/Einsia" target="_blank" rel="noopener" class="button ghost">GitHub</a>
    </div>
  </div>

  <div class="about-grid">
    <div class="about-card">
      <h3>Real-World Engineering</h3>
      <p>Problems with physical constraints, economic value, and measurable outcomes — not toy math benchmarks.</p>
    </div>
    <div class="about-card">
      <h3>Peak Performance Focus</h3>
      <p>We care about how far an agent can push a solution through iterative optimization, not just average accuracy.</p>
    </div>
    <div class="about-card">
      <h3>Community Driven</h3>
      <p>Open benchmarks, open contributions. Anyone can add new engineering problems via Pull Request.</p>
    </div>
  </div>
</Layout>

<script>
  function initTypewriter() {
    var el = document.querySelector(".typewriter");
    if (!el) return;
    var text = el.dataset.text || el.textContent;
    el.innerHTML = "";
    var i = 0;
    var speed = 22;
    function typeNext() {
      if (i <= text.length) {
        el.innerHTML = text.slice(0, i).replace(/\n/g, '<br>') + '<span class="cursor"></span>';
        i += 1;
        setTimeout(typeNext, speed);
      }
    }
    typeNext();
  }
  initTypewriter();
</script>
