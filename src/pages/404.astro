---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
---

<Layout title="404 Not Found">
  <Container>
    <div
      class="min-h-[calc(100vh-20rem)] flex items-center justify-center text-center">
      <div>
        <h1 class="font-serif text-6xl font-bold text-ink">404</h1>
        <p class="text-lg mt-4 text-ink-2">This page could not be found.</p>
        <div class="mt-8">
          <Link href="/" size="md">Back home</Link>
        </div>
      </div>
    </div>
  </Container>
</Layout>
