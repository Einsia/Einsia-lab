---
interface Props {
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted";
  class?: string;
  [x: string]: any;
}

const {
  size = "md",
  style = "primary",
  block,
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  md: "px-5 py-2.5",
  lg: "px-6 py-3",
};

const styles = {
  outline: "border border-ink hover:bg-ink text-ink hover:text-white",
  primary: "bg-ink text-white hover:bg-[#333333] border border-transparent",
};
---

<button
  {...rest}
  class:list={[
    "inline-flex items-center justify-center gap-1 rounded-lg text-sm font-medium text-center transition focus-visible:ring-2 ring-offset-2 ring-ink/10",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</button>
