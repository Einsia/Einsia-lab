---
import Layout from "@/layouts/Layout.astro";
import { getTaskPaths } from "@/lib/frontierTasks.js";

export function getStaticPaths() {
  return getTaskPaths();
}

const { task, prev, next, index, total, model, framework } = Astro.props;

const boards = [
  { label: "Model leaderboard", rows: model },
  { label: "Framework leaderboard", rows: framework },
];
---

<Layout
  title={`${task.name} · Frontier-Engineering`}
  description={task.description || `Per-task leaderboard for ${task.name}.`}>
  <article class="max-w-4xl mx-auto px-5 sm:px-6 pt-16 md:pt-20 pb-24">
    <header>
      <a
        href="/frontier-eng/tasks"
        class="text-xs font-semibold tracking-[0.08em] text-ink-3 hover:text-ink transition">
        ← All tasks
      </a>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <span class="rounded-full border border-line bg-paper-white px-3 py-1 text-xs text-ink-2">
          {task.domain}
        </span>
        <span class="text-xs text-ink-3 tabular-nums">
          Task {index} / {total}
        </span>
      </div>
      <h1
        class="mt-3 font-serif text-4xl md:text-5xl break-words font-bold tracking-tight text-ink leading-[1.08]">
        {task.name}
      </h1>
      {
        task.description && (
          <p class="mt-5 text-base md:text-lg text-ink-2 leading-relaxed">
            {task.description}
          </p>
        )
      }
    </header>

    <div class="mt-12 grid gap-10 md:grid-cols-2">
      {
        boards.map((board) => (
          <section>
            <h2 class="font-serif text-xl font-bold text-ink">{board.label}</h2>
            {board.rows.length > 0 ? (
              <div class="mt-4 overflow-x-auto">
                <table class="w-full text-sm border-collapse">
                  <thead>
                    <tr class="border-y border-ink/15 text-ink-3 text-left">
                      <th class="py-2 pr-3 font-medium w-8">#</th>
                      <th class="py-2 px-3 font-medium">Participant</th>
                      <th class="py-2 pl-3 font-medium text-right">Score</th>
                    </tr>
                  </thead>
                  <tbody>
                    {board.rows.map((r) => (
                      <tr
                        class:list={[
                          "border-b border-line",
                          r.rank === 1 && "font-semibold text-ink bg-paper-2",
                        ]}>
                        <td class="py-2 pr-3 text-ink-3 tabular-nums">
                          {r.rank}
                        </td>
                        <td class="py-2 px-3 text-ink">{r.name}</td>
                        <td class="py-2 pl-3 text-right tabular-nums text-ink">
                          {r.score}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="mt-4 text-sm text-ink-3">No submissions yet.</p>
            )}
          </section>
        ))
      }
    </div>
    <p class="mt-4 text-xs text-ink-3">
      Score is the normalized score for this task (0–100, higher is better).
    </p>

    <nav class="mt-14 pt-6 border-t border-line flex items-center justify-between gap-4 text-sm">
      {
        prev ? (
          <a
            href={`/frontier-eng/tasks/${prev.slug}`}
            class="text-accent hover:text-accent-hover transition">
            ← {prev.name}
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a
            href={`/frontier-eng/tasks/${next.slug}`}
            class="text-accent hover:text-accent-hover transition text-right">
            {next.name} →
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </article>
</Layout>
