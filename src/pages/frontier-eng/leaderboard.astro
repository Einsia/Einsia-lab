---
import Layout from "@/layouts/Layout.astro";

// Mean within-task rank (lower is better) over all 47 tasks.
const models = [
  { model: "GPT-5.4", rank: "3.54" },
  { model: "Claude Opus 4.6", rank: "3.63" },
  { model: "GLM-5", rank: "4.34" },
  { model: "DeepSeek V3.2", rank: "4.76" },
  { model: "Gemini 3.1 Pro Preview", rank: "5.53" },
  { model: "Grok 4.20", rank: "5.82" },
  { model: "SEED 2.0 Pro", rank: "5.86" },
  { model: "Qwen3 Coder Next", rank: "6.71" },
];
---

<Layout
  title="Frontier-Engineering · Leaderboard"
  description="Overall leaderboard for the Frontier-Engineering benchmark — frontier models ranked by mean within-task rank across 47 tasks.">
  <article class="max-w-4xl mx-auto px-5 sm:px-6 pt-16 md:pt-20 pb-24">
    <header>
      <a href="/frontier-eng/" class="inline-block text-xs font-semibold tracking-[0.08em] text-ink-3 hover:text-ink transition">← Frontier-Engineering</a>
      <h1
        class="mt-2 font-serif text-4xl sm:text-5xl md:text-6xl break-words font-bold tracking-tight text-ink leading-[1.05]">
        Overall Leaderboard
      </h1>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="rounded-full border border-line bg-paper-white px-3 py-1 text-xs text-ink-2">47 tasks</span>
        <span class="rounded-full border border-line bg-paper-white px-3 py-1 text-xs text-ink-2">12 domains</span>
      </div>
      <p class="mt-6 text-base md:text-lg text-ink-2 leading-relaxed max-w-3xl">
        Across <strong class="text-ink font-semibold">47 engineering tasks</strong>,
        the headline score is <strong class="text-ink font-semibold">average
        rank</strong> (lower is better). On each task, models are sorted by best
        feasible score and given a rank; average rank is the mean of those ranks
        across all tasks — comparing models without mixing incompatible units.
      </p>
    </header>

    <hr class="mt-10 border-line" />

    <!-- Frontier Models -->
    <section class="mt-10">
      <h2 class="font-serif text-3xl font-bold text-ink">Frontier Models</h2>
      <p class="mt-3 text-base text-ink-2 leading-relaxed max-w-3xl">
        Frontier AI models evaluated directly on engineering problems — no extra
        search frameworks, just raw model capability.
      </p>

      <h3 class="mt-8 text-xs font-semibold tracking-[0.08em] text-ink-3">
        Average rank
      </h3>
      <div class="mt-3 overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-y border-ink/15 text-ink-3 text-left">
              <th class="py-2 pr-4 font-medium w-10">#</th>
              <th class="py-2 px-4 font-medium">Model</th>
              <th class="py-2 pl-4 font-medium text-right">Avg. rank</th>
            </tr>
          </thead>
          <tbody>
            {
              models.map((row, i) => (
                <tr
                  class:list={[
                    "border-b border-line",
                    i === 0 && "font-semibold text-ink bg-paper-2",
                  ]}>
                  <td class="py-2 pr-4 text-ink-3 tabular-nums">{i + 1}</td>
                  <td class="py-2 px-4 text-ink">{row.model}</td>
                  <td class="py-2 pl-4 text-right tabular-nums text-ink">
                    {row.rank}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <h3 class="mt-12 text-xs font-semibold tracking-[0.08em] text-ink-3">
        Performance profile
      </h3>
      <p class="mt-3 text-base text-ink-2 leading-relaxed max-w-3xl">
        A Dolan–Moré performance profile: each curve shows how often a model
        stays near the best score on the bench within a given slack. Higher on
        the left means stronger and more consistent across the 47 tasks.
      </p>
      <figure
        class="mt-5 rounded-xl border border-line bg-paper-white shadow-sm overflow-hidden p-4">
        <img
          src="/frontier-eng/img/paper/performance_profile.png"
          alt="Dolan–Moré performance profile for frontier models on all 47 tasks."
          loading="lazy"
          class="w-full h-auto"
        />
      </figure>

      <p class="mt-8 text-sm text-ink-3">
        Browse the benchmark task by task →
        <a
          href="/frontier-eng/tasks"
          class="font-medium text-accent hover:underline underline-offset-4">
          open Tasks
        </a>
      </p>
    </section>

    <div class="mt-16 pt-6 border-t border-line">
      <a
        href="/frontier-eng/"
        class="inline-flex items-center gap-1 text-sm text-accent hover:text-accent-hover transition">
        ← Back to Frontier-Engineering
      </a>
    </div>
  </article>
</Layout>
