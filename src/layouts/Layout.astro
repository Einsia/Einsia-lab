---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "einsia Lab — Frontier AI Research" } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | einsia Lab</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #ffffff;
        --text: #0f172a;
        --muted: #6b7280;
        --border: #e5e7eb;
        --card-bg: rgba(255, 255, 255, 0.68);
        --border-hero: #cbd5e1;
        --accent: #111827;
        --pill: #f1f5f9;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-family: 'Space Mono', monospace;
        -webkit-font-smoothing: antialiased;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        font-size: 15px;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
      }

      a {
        color: var(--text);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
        text-underline-offset: 4px;
      }

      h1, h2, h3 {
        line-height: 1.25;
      }

      p {
        margin: 0 0 16px;
      }

      code {
        font-family: "SF Mono", "Fira Code", monospace;
        font-size: 0.875em;
        background: #f7f7f8;
        border: 1px solid #ebebeb;
        padding: 0.15em 0.4em;
        border-radius: 4px;
        color: #0f172a;
      }

      .container {
        width: 90%;
        max-width: 980px;
        margin: 0 auto;
      }

      main {
        flex: 1;
        opacity: 0;
        transition: opacity 0.35s ease;
      }

      main.page-visible {
        opacity: 1;
      }

      /* Header */
      .site-header {
        border-bottom: 1px solid var(--border);
        padding: 18px 0;
        background: var(--bg);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .header-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .logo {
        font-weight: 700;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .logo:hover {
        text-decoration: none;
      }

      .logo:hover .logo-text {
        text-decoration: underline;
        text-underline-offset: 4px;
      }

      .logo-text {
        font-size: 1rem;
      }

      nav a {
        margin-left: 28px;
        font-size: 14px;
      }

      nav a:hover {
        text-decoration: underline;
        text-underline-offset: 8px;
      }

      nav a.active {
        text-decoration: underline;
        text-underline-offset: 8px;
        text-decoration-thickness: 1.5px;
        color: var(--text);
        font-weight: 700;
      }

      /* Footer */
      .site-footer {
        border-top: 1px solid var(--border);
        padding: 16px 0 24px;
        color: var(--muted);
        font-size: 13px;
        margin-top: auto;
      }

      .site-footer .container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
      }

      .social-links {
        display: flex;
        gap: 12px;
      }

      .social-link {
        color: var(--muted);
        display: flex;
        align-items: center;
        transition: color 0.15s;
      }

      .social-link:hover {
        color: var(--text);
        text-decoration: none;
      }

      /* Hero */
      .hero {
        padding: 40px 0 40px;
      }

      .typewriter {
        display: block;
        min-height: 2.5em;
      }

      .hero-divider {
        width: 20%;
        height: 2px;
        background: var(--border-hero);
        margin: 20px 0;
      }

      .cursor {
        display: inline;
        border-right: 2px solid var(--text);
        margin-left: 1px;
        animation: caret 0.9s steps(1) infinite;
      }

      @keyframes caret {
        50% { opacity: 0; }
      }

      /* Dictionary entry */
      .dict-entry {
        margin-top: 48px;
        padding: 28px 0px;
      }

      .dict-headword {
        display: flex;
        align-items: baseline;
        gap: 16px;
        margin-bottom: 10px;
      }

      .dict-word {
        font-size: clamp(32px, 4vw, 48px);
        font-weight: 700;
        letter-spacing: -0.5px;
        line-height: 1.1;
      }

      .dict-phonetic {
        font-size: clamp(16px, 2vw, 20px);
        color: var(--muted);
        font-style: italic;
        font-weight: 400;
      }

      .dict-body {
        font-size: 16px;
        line-height: 1.7;
      }

      .dict-pos {
        font-style: italic;
        color: var(--muted);
        margin-right: 6px;
      }

      .dict-def {
        color: var(--text);
      }

      /* Page header */
      .page-header {
        padding: 40px 0 16px;
      }

      .eyebrow {
        display: inline-block;
        letter-spacing: 2px;
        font-size: 14px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 8px;
        font-family: 'Space Mono', monospace;
      }

      .page-header h1 {
        font-size: clamp(1.4rem, 3vw, 2rem);
        font-weight: 700;
        letter-spacing: -0.5px;
      }

      /* Benchmarks list */
      .list {
        display: grid;
        gap: 14px;
        margin-bottom: 40px;
      }

      @keyframes card-rise {
        from {
          opacity: 0;
          transform: translateY(32px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .list .card {
        animation: card-rise 0.52s cubic-bezier(0.22, 0.61, 0.36, 1) both;
        animation-play-state: paused;
      }

      main.cards-ready .list .card {
        animation-play-state: running;
      }

      .list .card:nth-child(1)  { animation-delay: 0.05s; }
      .list .card:nth-child(2)  { animation-delay: 0.13s; }
      .list .card:nth-child(3)  { animation-delay: 0.21s; }
      .list .card:nth-child(4)  { animation-delay: 0.29s; }
      .list .card:nth-child(5)  { animation-delay: 0.37s; }

      .card {
        padding: 14px 16px;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--card-bg);
        transition: transform 0.22s ease, border-color 0.22s ease;
      }

      .list .card:hover {
        transform: translateY(-2px);
        border-color: var(--border-hero);
      }

      .card-row {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 14px;
        align-items: stretch;
      }

      .card-image {
        width: 100%;
        height: 100%;
        min-height: 120px;
        background-size: contain;
        background-position: center;
        background-repeat: no-repeat;
        border-radius: 8px;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
      }

      .card-body {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .card-meta {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 4px;
      }

      .card-body h3 {
        font-size: 1rem;
        margin: 0 0 6px;
      }

      .card-body h3 a {
        color: var(--text);
      }

      .card-body p {
        font-size: 14px;
        color: var(--muted);
        margin: 0;
        line-height: 1.6;
      }

      /* CTA */
      .cta {
        margin: 40px 0 60px;
        padding: 20px;
        border: 1px dashed var(--border);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
      }

      .cta p {
        margin: 0;
        font-size: 14px;
        color: var(--muted);
      }

      .cta-actions {
        display: flex;
        gap: 10px;
      }

      .button {
        padding: 10px 16px;
        border: 1px solid var(--accent);
        border-radius: 6px;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        font-family: 'Space Mono', monospace;
      }

      .button.primary {
        background: var(--accent);
        color: #fff;
      }

      .button.primary:hover {
        text-decoration: none;
        background: #374151;
      }

      .button.ghost {
        background: transparent;
        color: var(--text);
      }

      .button.ghost:hover {
        text-decoration: none;
        background: #f1f5f9;
      }

      /* About section on home */
      .about-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
        margin: 40px 0 10px;
      }

      .about-card {
        padding: 16px;
        border: 1px solid var(--border);
        border-radius: 10px;
      }

      .about-card h3 {
        font-size: 0.9rem;
        margin: 8px 0 6px;
      }

      .about-card p {
        font-size: 13px;
        color: var(--muted);
        margin: 0;
        line-height: 1.6;
      }

      /* Back link */
      .back-link {
        margin-top: 24px;
      }

      .back-link a {
        font-size: 13px;
        color: var(--muted);
      }

      @media (max-width: 640px) {
        nav a { margin-left: 10px; }
        .hero { padding-top: 40px; }
        .card-row { grid-template-columns: 1fr; }
        .card-image { min-height: 80px; }
        .site-footer .container { flex-direction: column; align-items: flex-start; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-content">
        <a class="logo" href={import.meta.env.BASE_URL}>
          <span class="logo-text">einsia Lab</span>
        </a>
        <nav>
          <a href={import.meta.env.BASE_URL} class={pathname === '/' ? 'active' : ''}>Home</a>
          <a href={`${import.meta.env.BASE_URL}benchmarks`} class={pathname === '/benchmarks' ? 'active' : ''}>Benchmarks</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>einsia Lab · <a href="mailto:lab@einsia.ai">lab@einsia.ai</a></p>
        <div class="social-links">
          <a href="https://github.com/Einsia" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>
    <script>
      // Page fade-in
      var mainEl = document.querySelector('main');
      if (mainEl) {
        mainEl.style.transition = 'none';
        mainEl.style.opacity = '1';
        setTimeout(function() {
          mainEl.classList.add('page-visible');
          setTimeout(function() {
            mainEl.classList.add('cards-ready');
          }, 380);
        }, 80);
      }
    </script>
  </body>
</html>
