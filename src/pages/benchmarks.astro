---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Benchmarks" description="AI engineering benchmarks — einsia Lab">
  <section class="page-header">
    <div class="eyebrow">Benchmarks</div>
    <h1>Define the Frontier and Track the Acceleration.</h1>
  </section>

  <section class="list">
    <article class="card card-row">
      <div class="card-image" style="background: #f7f7f8; display: flex; align-items: center; justify-content: center;">
        <span style="font-size: 2.5rem; line-height: 1;">⚙️</span>
      </div>
      <div class="card-body">
        <div class="card-meta">
          🏆 Active · Engineering Optimization
        </div>
        <h3><a href={`${import.meta.env.BASE_URL}frontier-eng/index.html`}>Frontier-Engineering</a></h3>
        <p>
          A benchmark evaluating AI agents on open-ended engineering optimization problems — from aerospace scheduling and EDA to quantum circuit design, fiber optics, and battery control. 47 tasks across 12+ domains.
        </p>
      </div>
    </article>
  </section>

  <div class="cta">
    <p>Want to contribute a new engineering benchmark? Open a Pull Request on GitHub.</p>
    <div class="cta-actions">
      <a href="https://github.com/Einsia" target="_blank" rel="noopener" class="button primary">View on GitHub</a>
    </div>
  </div>
</Layout>
