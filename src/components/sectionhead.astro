---
const { align = "center" } = Astro.props;
---

<div class:list={["mt-16", align === "center" && "text-center"]}>
  <h1
    class="font-serif text-3xl sm:text-4xl lg:text-5xl break-words font-bold tracking-tight text-ink">
    <slot name="title">Title</slot>
  </h1>
  <p class="text-lg mt-4 text-ink-2">
    <slot name="desc">Some description goes here</slot>
  </p>
</div>
