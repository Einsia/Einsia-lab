---
import Layout from "../layouts/Layout.astro";
import ParticleCanvas from "../components/ParticleCanvas.astro";

const frontierUrl = `${import.meta.env.BASE_URL}frontier-eng/index.html`;
const browserSkillUrl = `${import.meta.env.BASE_URL}browser-skill-distillation/index.html`;
const browserSkillPdfUrl = `${import.meta.env.BASE_URL}browser-skill-distillation/assets/paper.pdf`;
---

<Layout
  title="News"
  description="Lab updates, releases, and progress — Navers lab"
>
  <ParticleCanvas />
  <section class="hero">
    <h1 class="hero-title">News</h1>
    <div class="hero-divider"></div>
    <p class="hero-subtitle">
      Benchmarks, releases, collaborations, and other lab updates — one place to track how the frontier moves.
    </p>
  </section>

  <div class="news-grid">
    <article class="about-card">
      <span class="about-card-badge">Benchmarks · Active</span>
      <h3><a href={frontierUrl}>Frontier-Engineering</a></h3>
      <p>
        Open engineering benchmark: agents on optimization across aerospace scheduling, EDA, quantum circuits, fiber optics, battery control, and more. 47 tasks across 12+ domains.
      </p>
      <div class="news-card-actions">
        <a href={frontierUrl} class="button primary">Open benchmark</a>
        <a href="https://github.com/Einsia" target="_blank" rel="noopener" class="button ghost">GitHub</a>
      </div>
    </article>

    <article class="about-card">
      <span class="about-card-badge">Paper / Browser agents</span>
      <h3><a href={browserSkillUrl}>Browser Using Bench</a></h3>
      <p>
        Paper showcase for scalable behaviour cloning on browser tasks via distributed skill summarization, with a method overview, WebArena-Hard results, and PDF preview.
      </p>
      <div class="news-card-actions">
        <a href={browserSkillUrl} class="button primary">Open paper page</a>
        <a href={browserSkillPdfUrl} class="button ghost">PDF</a>
      </div>
    </article>
  </div>

  <div class="cta">
    <p>More updates coming soon. To contribute benchmarks or share results, open a pull request on GitHub.</p>
    <div class="cta-actions">
      <a href="https://github.com/Einsia" target="_blank" rel="noopener" class="button primary">Contribute on GitHub</a>
    </div>
  </div>
</Layout>

<style>
  .hero,
  .news-grid,
  .cta {
    position: relative;
    z-index: 1;
  }

  .news-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin: 12px 0 10px;
  }

  .news-grid .about-card h3 {
    font-size: 1.15rem;
    margin-bottom: 10px;
  }

  .news-grid .about-card h3 a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .news-grid .about-card h3 a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .news-card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  .news-card-actions .button {
    margin: 0;
  }

  .news-grid .about-card p {
    margin-bottom: 0;
  }
</style>
